{
  "manifest_version": 3,
  "name": "XDM Browser Integration",
  "version": "1.0.0",
  "description": "Integrates browser with Xtreme Download Manager",
  "background": { "service_worker": "bg.js" },
  "action": { "default_title": "XDM" },
  "host_permissions": ["<all_urls>"],
  "permissions": ["downloads", "cookies", "tabs", "nativeMessaging", "storage", "scripting"]
}
